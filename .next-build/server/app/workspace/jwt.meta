{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/workspace/layout,_N_T_/workspace/jwt/layout,_N_T_/workspace/jwt/page,_N_T_/workspace/jwt"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/workspace/jwt/__PAGE__",
    "/workspace/jwt",
    "/workspace",
    "/_index",
    "/_head"
  ]
}
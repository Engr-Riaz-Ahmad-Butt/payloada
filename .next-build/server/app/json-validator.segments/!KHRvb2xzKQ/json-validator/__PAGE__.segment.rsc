0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"How does Payloada show invalid JSON?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"It reports the parser error and the matching line and column so you can correct the payload quickly.\"}},{\"@type\":\"Question\",\"name\":\"Can it help fix broken JSON?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Payloada includes repair assistance for common mistakes like trailing commas and lightly malformed input.\"}},{\"@type\":\"Question\",\"name\":\"Does Payloada upload my JSON?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The main workspace is local-first. Formatting, diffing, decoding, validation, and most converters stay in the browser unless you explicitly use AI or sharing features.\"}},{\"@type\":\"Question\",\"name\":\"Does validation work for pasted API responses?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. It is designed for real developer payloads, including large nested responses.\"}}]}"}}],["$","main",null,{"className":"min-h-screen bg-obsidian-base text-text-primary","children":[["$","section",null,{"className":"border-b-[0.5px] border-ui-border bg-surface-elevated px-4 py-6 sm:px-6 lg:px-8","children":["$","div",null,{"className":"mx-auto max-w-5xl","children":[["$","$L2",null,{"href":"/","className":"text-sm text-text-tertiary transition-colors hover:text-brand","children":"Back to Payloada"}],["$","h1",null,{"className":"mt-3 text-3xl font-semibold tracking-[-0.02em] text-text-primary","children":"JSON validator"}],["$","p",null,{"className":"mt-2 max-w-3xl text-sm leading-6 text-text-secondary","children":"Check syntax, spot structural problems, and move directly into fixes without leaving the workspace."}]]}]}],["$","section",null,{"className":"border-b-[0.5px] border-ui-border bg-surfa
0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"When is graph view better than tree view?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Graph view is helpful for large or deeply nested payloads where visual structure is easier to follow than indented text.\"}},{\"@type\":\"Question\",\"name\":\"Can I change the layout direction?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Payloada's graph view includes layout direction controls.\"}},{\"@type\":\"Question\",\"name\":\"Does Payloada upload my JSON?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The main workspace is local-first. Formatting, diffing, decoding, validation, and most converters stay in the browser unless you explicitly use AI or sharing features.\"}},{\"@type\":\"Question\",\"name\":\"Does graph view use the same JSON as the editor?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. It visualizes the parsed editor payload directly.\"}}]}"}}],["$","main",null,{"className":"min-h-screen bg-obsidian-base text-text-primary","children":[["$","section",null,{"className":"border-b-[0.5px] border-ui-border bg-surface-elevated px-4 py-6 sm:px-6 lg:px-8","children":["$","div",null,{"className":"mx-auto max-w-5xl","children":[["$","$L2",null,{"href":"/","className":"text-sm text-text-tertiary transition-colors hover:text-brand","children":"Back to Payloada"}],["$","h1",null,{"className":"mt-3 text-3xl font-semibold tracking-[-0.02em] text-text-primary","children":"JSON graph visualizer"}],["$","p",null,{"className":"mt-2 max-w-3xl text-sm leading-6 text-text-secondary","children":"Explore nested JSON visually as a connected graph without leaving the main editor flow."}]]}]}],["$","section",null,{"className":"border-b-[0.5px] border-ui-border bg-surface","children":["$","div",null,{"className":"mx-